@model Albat.Models.DailyLogModel
@inject IHttpContextAccessor HttpContextAccessor
@{
    <nav class="home-section2" style="background: radial-gradient(circle, rgba(238,174,228,1) 61%, rgba(148,187,233,1) 100%);">
        <div class="sidebar-button">
            @*<span class="dashboard" style="text-shadow: 2px 2px 5px red;font-size:35px;">Albatrose Ladies Professional Saloon</span>*@
            <span class="dashboard" style="text-shadow: 2px 2px 5px red;font-size:35px;">DailyLog Details</span>
        </div>
        <div style="display:grid; grid-template-columns: 1fr 1fr; grid-column-gap: 7px; grid-row-gap: 7px">
            <a href="/Home/DailyLog?id="><i class="fa fa-refresh fa-spin" style="color:black;font-size:35px"></i></a>
        </div>
    </nav>
    <br />
    <body>
        <form asp-action="DailyLog">
            <div style="display:grid;grid-template-columns:0.2fr 0.1fr 0.1fr 1fr 0.1fr 1fr 0.1fr 0.8fr 0.3fr 0.5fr;grid-column-gap:10px;grid-row-gap:10px">
                <label></label>
                <input type="checkbox" id="checkedvalue" asp-for="@Model.CheckBox" style="height:20px;margin:7px" />
                <label style="font-size:28px; font-weight:bold">From</label>
                <input type="date" id="start" class="borderheight" asp-for="@Model.FromDate" my-date-format="DD/MM/YYYY" />
                <label style="font-size:28px; font-weight:bold">To</label>
                <input type="date" id="start" class="borderheight" asp-for="@Model.ToDate" my-date-format="DD/MM/YYYY" />
                <label style="font-size:28px; font-weight:bold">Staffs</label>
                <div>
                    <input class="borderheight" list="employee" id="Employee" asp-for="@Model.Employee" placeholder="Select Staff" style="height:35px;border-radius:5px;margin-right:100px;" />
                    <datalist class="borderheight" id="employee">
                        @foreach (var item in Model.Employees)
                        {
                            <option value="@item.Text"></option>
                        }
                    </datalist>
                </div>
                <button class="bookmarkBtn" onclick="return funcall()" formmethod="post">
                    <span class="IconContainer">
                        <svg viewBox="0 0 384 512" height="0.9em" class="icon">
                            <path d="M0 48V487.7C0 501.1 10.9 512 24.3 512c5 0 9.9-1.5 14-4.4L192 400 345.7 507.6c4.1 2.9 9 4.4 14 4.4c13.4 0 24.3-10.9 24.3-24.3V48c0-26.5-21.5-48-48-48H48C21.5 0 0 21.5 0 48z"></path>
                        </svg>
                    </span>
                    <p class="text">Save</p>
                </button>
                <button class="bookmarkBtn" onclick="report()">
                    <span class="IconContainer">
                        <svg viewBox = "0 0 384 512" height="0.9em" class="icon">
                            <path d = "M0 48V487.7C0 501.1 10.9 512 24.3 512c5 0 9.9-1.5 14-4.4L192 400 345.7 507.6c4.1 2.9 9 4.4 14 4.4c13.4 0 24.3-10.9 24.3-24.3V48c0-26.5-21.5-48-48-48H48C21.5 0 0 21.5 0 48z"></path>
                        </svg>
                    </span>
                    <p class="text">Report</p>
                </button> 
                <label></label>
            </div>
            <input type="text" id="status" asp-for="@Model.Status" hidden />
        </form>
        <br />
        @if (HttpContextAccessor.HttpContext.Session.GetString("Login") == "EMP0001")
        {
            <div style="margin:5px"><label style="font-weight:900;font-size:1.8em">Grand Total : @Model.GrandTotal</label></div>
        }
        <div style="overflow: scroll; height: 765px;">
            <table class="styletable" style="width:100%;" id="tableDaily">
                <thead>
                    <tr>
                        <th>SNo</th><th>Client Name</th><th>Contact</th><th>Service Name</th><th>Qty</th><th>Price</th><th>Total</th><th>Service Date</th><th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.DailyLog != null)
                    {
                        @for (int ii = 0; ii < Model.DailyLog.Count; ii++)
                        {
                            <tr>
                                <td>@Model.DailyLog[ii].Sno</td><td>@Model.DailyLog[ii].ClientName</td><td>@Model.DailyLog[ii].Contact</td>
                                <td>@Model.DailyLog[ii].ServiceName</td><td>@Model.DailyLog[ii].Qty</td><td>@Model.DailyLog[ii].Amount</td>
                                <td>@Model.DailyLog[ii].Total</td><td>@Model.DailyLog[ii].ServiceDate.ToString("dd-MM-yyyy HH:mm")</td><td>@Model.DailyLog[ii].Date.ToString("dd-MM-yyyy HH:mm")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </body>
    <script>
        function funcall() {
            document.getElementById("status").value = "false";
        }
        function report(){
            $.ajax({
                url: "/Home/ExcelReport",
                type: "POST",
                data: { 'start' : document.getElementById("start").value, 'end' : document.getElementById("end").value },
                xhrFields: { responseType: 'blob' },
                success: function (result) {
                    var a = document.createElement('a');
                    var url = window.URL.createObjectURL(result);
                    a.href = url;
                    a.download = 'Report.xlsx';
                    document.body.append(a);
                    a.click();
                    a.remove();
                    window.URL.revokeObjectURL(url);
                }
            });
        }
    </script>
    <style>
        .borderheight {
            height: 32px;
            border-radius: 5px;
            border-color: gray;
            width: 70%;
            background: radial-gradient(circle at 10% 20%, rgb(220, 182, 232) 100.2%,rgb(163, 175, 243) 0% );
            font-weight: bold;
        }
    </style>
}
