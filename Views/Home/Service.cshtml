@model Albat.Models.ServiceModel
@{

    <nav class="home-section2" style="background: radial-gradient(circle, rgba(238,174,228,1) 61%, rgba(148,187,233,1) 100%);">
        <div class="sidebar-button">
            <span class="dashboard" style="text-shadow: 2px 2px 5px red;font-size:35px;">Services</span>
        </div>
        <div style="display:grid; grid-template-columns: 1fr 1fr; grid-column-gap: 7px; grid-row-gap: 7px">
            <a href="/Home/Service?id="><i class="fa fa-refresh fa-spin" style="color:black;font-size:35px"></i></a>
        </div>
    </nav>
    <br />
    <body>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;grid-column-gap:20px;grid-row-gap:5px;margin:10px;">
            <label class="label">Service No</label>
            <label class="label">Date of Billing <span style="color:red">*</span></label>
            <label class="label">Contact<span style="color:red">*</span></label>
            <label class="label">Client Name <span style="color:red">*</span></label>
            <input type="text" id="servicecode" class="borderheight" asp-for="@Model.ServiceCode" readonly />
            <input type="datetime-local" id="start" class="borderheight" />
            <input type="text" id="contact" maxlength="10" class="borderheight" placeholder="Enter the Contact" autocomplete="off" required />
            <input type="text" id="clientname" class="borderheight" placeholder="Enter the Client Name" autocomplete="off" />
            <label class="label">Services</label>
            <label class="label">Staffs <span style="color:red">*</span></label>
            <label class="label">Date Time Of Billing</label>
            <label class="label">MemberShip </label>
            <div>
                <input type="search" class="borderheight" list="options" id="SelectedValue" placeholder="Select Service" style="height:35px;border-radius:5px;margin-right:100px;" />
                <datalist class="borderheight" id="options">
                    @foreach (var item in Model.Items)
                    {
                        <option value="@item.Text"></option>
                    }
                </datalist>
            </div>
            <div>
                <input type="search" class="borderheight" list="employee" id="Employee" placeholder="Select Service" style="height:35px;border-radius:5px;margin-right:100px;" />
                <datalist class="borderheight" id="employee">
                    @foreach (var item in Model.Employee)
                    {
                        <option value="@item.Text" data-value="@item.Value"></option>
                    }
                </datalist>
            </div>
            <input type="text" id="billdate" onchange="myFunction()" class="borderheight" autocomplete="off" readonly />
            <select class="borderheight" id="member"><option>No</option><option>Yes</option><option>Offer</option></select>
        </div>
        <div id="approveRbt">@(ViewData["idChecked"])</div>
        <button class="bookmarkBtn" onclick="saveallData()" style="margin:10px">
            <span class="IconContainer">
                <svg viewBox="0 0 384 512" height="0.9em" class="icon">
                    <path d="M0 48V487.7C0 501.1 10.9 512 24.3 512c5 0 9.9-1.5 14-4.4L192 400 345.7 507.6c4.1 2.9 9 4.4 14 4.4c13.4 0 24.3-10.9 24.3-24.3V48c0-26.5-21.5-48-48-48H48C21.5 0 0 21.5 0 48z"></path>
                </svg>
            </span>
            <p class="text">Save</p>
        </button>
        <div style="margin:10px;overflow: scroll;height: 635px;">
            <table class="styletable" id="myTable">
                <thead>
                    <tr>
                        <th>Service Name</th>
                        <th>Qty</th>
                        <th>Amount</th>
                        <th>Total</th>
                        <th>Delete</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
                <tfoot>
                    <tr>
                        <td style="height: 30px;text-align: center;"></td>
                        <td style="height: 30px;text-align: center;"></td>
                        <td style="height: 30px;text-align: center;" class="borderheight">Total</td>
                        <td style="height: 30px;text-align: center;"class="borderheight" id="grandTotal"></td>
                        <td style="height: 30px;text-align: center;"></td> @*style="background-color:honeydew;color:black;border:1px solid black" *@
                    </tr>
                </tfoot>
            </table>
        </div>
    </body>
    <script>
        document.getElementById('SelectedValue').addEventListener('change', function () {
            var select = this.value;
            document.getElementById("approveRbt").value = select;
            var membership = document.getElementById("member").value;
            var parameter = '?id=~' + document.getElementById("approveRbt").value + '~' + membership;
            $.ajax({
                type: "POST",
                url: "/Home/Services?id=" + parameter,
                success: function (response) {
                    if(response == "false"){
                        alert('Again Select Services !');
                    }
                    else{
                        $('#myTable tbody').append(response);
                    }
                }
            });
        });
    </script>
    <script>
        function saveallData() {
            var servicecode = document.getElementById("servicecode").value;
            var dates = document.getElementById("start").value;
            var contact = document.getElementById("contact").value;
            var client = document.getElementById("clientname").value;
            var datebill = document.getElementById("billdate").value;
            var phoneNum = /^\(?([0-9]{3})\)?[-. ]?([0-9]{3})[-. ]?([0-9]{4})$/; @*Contact Check RegEx Method*@
            var phone = phoneNum.test(contact);
            var staff = document.getElementById("Employee").value;

            if (!phoneNum.test(contact)) {
                var element = document.querySelector("#contact");
                element.classList.replace("borderheight", "subborderheight");
                alert("Please Check Contact");
                return false;
            }
            else if (client === '') {
                var element = document.querySelector("#client");
                element.classList.replace("borderheight", "subborderheight");
                alert("Please Enter Cilent Name");
                return false;
            }
            else if (dates === '') {
                var element = document.querySelector("#start");
                element.classList.replace("borderheight", "subborderheight");
                alert("Please Choose the Date of Billing ");
                return false;
            }
            else if (staff === 'Select...' || staff === '') {
                var element = document.querySelector("#Employee");
                element.classList.replace("borderheight", "subborderheight");
                alert("Please Choose the Staff Name ");
                return false;
            }
            var valid = true;
            var table = document.getElementById("myTable");
            var rows = table.getElementsByTagName("tr");
            var header = table.getElementsByTagName("th");
            for (var i = 1; i < rows.length-1; i++) {
                var cells = rows[i].getElementsByTagName("td");
                for (var j = 0; j < cells.length-1; j++) {
                    cells[j].classList.remove("error");              // reset
                    if (cells[j].innerText.trim() === "") {
                        cells[j].classList.add("error");
                        cells[j].setAttribute("tabindex", "0");      // focus enable
                        cells[j].focus();
                        alert("Row " + i + " " + header[j].innerText + " was Empty");
                        valid = false;
                        return false;
                    }
                }
            }
            if(valid){
                var tableData = [];
                $('#myTable tbody tr').each(function () {
                    var rowData = {
                        Services: $(this).find('td:eq(0)').text(),
                        Quentity: $(this).find('td:eq(1)').text(),
                        Price: $(this).find('td:eq(2)').text(),
                        Total: $(this).find('td:eq(3)').text(),
                        ServiceCode: $("#servicecode").val(),
                        Date: $("#start").val(),
                        Contact: $("#contact").val(),
                        Client: $("#clientname").val(),
                        Staff: staff,
                    };
                    tableData.push(rowData);
                });
                $.ajax({
                    type: "POST",
                    url: "/Home/SaveDatas",
                    data: JSON.stringify(tableData),
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    success: function (response) {
                        alert("Successfully Saved");
                    }
                });
            }
        }
    </script>
    <script>
        function myFunction1(icon) {
            let loopadd = 0;
            let nooftotals = 0;
            const tdElement = icon.closest('td');
            var $row = $(icon).closest('tr');
            var amount = $row.find('td:eq(2)').text();
            var inputval = tdElement.textContent;
            const tdElements = document.querySelectorAll('#myTable td');
            var a = 1;
            var b;
            tdElements.forEach(td => {
                const input = td.querySelector('input');
                if (a == "3") {
                    @*b = td.textContent.trim();*@
                    b = amount;
                }
                a++;
            });
            var add = formatCost(Number(b) * Number(inputval));
            $row.find('td:eq(3)').text(add);                                                     //Entha Row la Value change pantromo antha row la matum affect agum;

            $('#myTable tbody tr').each(function () {
                nooftotals = $(this).find('td').eq(3).text().replace(',', '').trim();
                loopadd = Number(nooftotals) + Number(loopadd);                                  //Total value Calculate and
            })
            document.getElementById("grandTotal").innerHTML = formatCost(Number(loopadd));      //Total value Set
        }
    </script>
    <script>
        function removeRow(button) {
            const tdElement = button.closest('td');
            var $row = $(button).closest('tr');
            var amount = $row.find('td:eq(3)').text().replace(',', '');
            var total = document.getElementById("grandTotal").innerText.replace(',', '');
            let grand = Number(total) - Number(amount);
            document.getElementById("grandTotal").innerText = formatCost(Number(grand));
            var row = button.parentNode.parentNode;                                     // Get the parent row of the button
            row.parentNode.removeChild(row);                                            // Remove the row from the table
        }
    </script>
    <script>
        function myFunction() {
            var d = new Date();
            var datestring = d.getDate() + "-" + (d.getMonth() + 1) + "-" + d.getFullYear() + " " + d.getHours() + ":" + d.getMinutes();
            var n = d.toLocaleDateString("en-IN");
            alert(datestring);
            document.getElementById("").innerHTML = n;
        }
    </script>
    <script>
        window.onload = function () {
            var d = new Date();
            var datestring = d.getDate() + "-" + (d.getMonth() + 1) + "-" + d.getFullYear() + " " + d.getHours() + ":" + d.getMinutes();
            var n = d.toLocaleDateString("en-IN");
            document.getElementById("billdate").value = datestring;                 // Setting the input value
        };
    </script>
    <script>
        function formatCost(value) {
            if (isNaN(value)) {
                return Number(0).toFixed(2);
            }
            else {
                return Number(value).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }
        }
    </script>
}
<style>
    .home-section1 {
        background: #ffff7f;
        position: relative;
        width: calc(100% - 244px);
        height: 100vh;
        left: 240px;
        transition: all 0.5s ease;
        overflow-y: scroll;
        overflow-x: hidden;
    }
    .sidebar.active ~ .home-section1 {
        width: calc(100% - 60px);
        left: 60px;
    }
    .home-section1 nav {
        width: 100%;
        height: 60px;
        background: #ffff7f;
        padding: 0 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: all 0.5s ease;
    }
    .sidebar.active ~ .home-section1 nav {
        width: calc(100% - 60px);
        left: 60px;
    }
    .home-section1 nav .sidebar-button {
        display: flex;
        align-items: center;
        font-size: 20px;
        font-weight: 500;
    }
    .home-section1 nav .sidebar-button i {
        font-size: 35px;
        margin-right: 10px;
        display: flex;
    }
    .styletable {
        border-collapse: collapse;
        width: 100%;
        margin: 5px;
        font-family: sans-serif;
        box-shadow: 0 0 20px rgba(0, 0, 0, 0.15);
    }
    .styletable thead tr {
        background-color: black;
        border: 2px solid white;
        height: 40px;
        color: white;
        position: sticky;
        top: 0;
        z-index: 1;
    }
    .styletable th,
    .styletable td {
        text-align: center;
        padding: 12px;
    }
    .styletable tbody tr {
        border-bottom: 1px solid #dddddd;
    }
    tr:nth-child(even) {
        background-color: #dddddd;
    }
    .borderheight {
        height: 32px;
        border-radius: 5px;
        border-color: gray;
        background: radial-gradient(circle at 10% 20%, rgb(220, 182, 232) 100.2%,rgb(163, 175, 243) 0% );
        font-size: 1.0em;
        font-weight: bold;
    }
    .subborderheight {
        height: 32px;
        border-radius: 5px;
        border-color: red;
    }
</style>

